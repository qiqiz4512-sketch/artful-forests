VITE_SUPABASE_URL=https://giooyiclaivgxmedfljk.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# SecondMe SSO (Supabase OAuth / OIDC)
VITE_SECONDME_SSO_ENABLED=true
# Preferred for Supabase Enterprise SSO (recommended)
# Example: VITE_SECONDME_SSO_PROVIDER_ID=sso_1234567890abcdef
VITE_SECONDME_SSO_PROVIDER_ID=

# Optional fallback (OAuth/OIDC provider name). Only set when your Supabase project
# has this OAuth provider enabled; otherwise you'll get "Unsupported provider".
VITE_SECONDME_OAUTH_PROVIDER=
VITE_SECONDME_OAUTH_SCOPE=openid profile email
VITE_SECONDME_OAUTH_ACCESS_TYPE=offline
VITE_SECONDME_OAUTH_PROMPT=consent

# ──────────────────────────────────────────
# 树木 Agent 对话 LLM 配置（选择其一填写即可）
# ──────────────────────────────────────────

# 方案 A: Ollama 本地（免费，无需 API Key）
# 安装: https://ollama.ai  然后运行: ollama pull qwen2.5:3b
# 下面取消注释即可启用:
# VITE_OLLAMA_BASE_URL=http://localhost:11434
# VITE_OLLAMA_MODEL=qwen2.5:3b

# 方案 B: OpenAI
# VITE_OPENAI_API_KEY=sk-...
# VITE_OPENAI_MODEL=gpt-4o-mini

# 方案 C: Together AI（有免费额度）
# 申请 key: https://together.ai
# VITE_TOGETHER_API_KEY=...
# VITE_TOGETHER_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo

# 方案 D: 任意 OpenAI 兼容接口（如 SiliconFlow、DeepSeek 等）
# VITE_OPENAI_API_KEY=your-key
# VITE_OPENAI_API_BASE=https://api.siliconflow.cn/v1
# VITE_OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct
# Optional: when provider=oidc and Supabase expects a specific query provider key.
# Example: VITE_SECONDME_OAUTH_QUERY_PROVIDER=secondme
VITE_SECONDME_OAUTH_QUERY_PROVIDER=
